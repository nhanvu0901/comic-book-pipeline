  "text_blocks": [
    {
      "panel_index": 0,
      "text": "...I NEED YA.",
      "type": "speech",
      "speaker": "The Thing"
    },
    {
      "panel_index": 1,
      "text": "I'M SO SORRY. THIS IS MY FAULT... I DIDN'T LISTEN... I SHOULDA LISTENED...",
      "type": "speech",
      "speaker": "The Thing"
    },
    {
      "panel_index": 1,
      "text": "YOU DID WHAT WAS BESSSST...",
      "type": "speech",
      "speaker": "The Thing"
    },
    {
      "panel_index": 2,
      "text": "THERE AIN'T NO WE. THERE AIN'T NO FANTASTIC FOUR.",
      "type": "speech",
      "speaker": "Venom"
    },
    {
      "panel_index": 2,
      "text": "...REED WAS SSSSELFISH. HE WANTED THE SUIT FOR HIMSELF, AND HE WANTED TO KEEP YOU FROM USSSSING IT. WE ARE BETTER WITHOUT HIM, BEN.",
      "type": "speech",
      "speaker": "Venom"
    },
    {
      "panel_index": 2,
      "text": "WE?",
      "type": "speech",
      "speaker": "Venom"
    },
    {
      "panel_index": 3,
      "text": "THERE AIN'T NO WE.",
      "type": "speech",
      "speaker": "The Thing"
    },
    {
      "panel_index": 4,
      "text": "IT'S JUST ME!",
      "type": "speech",
      "speaker": "The Thing"
    }
