# === LLM (OpenRouter) ===
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Single-model legacy var (kept for callers that don't use the chain yet).
# OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# === Text LLM fallback chain (Stage 1 / 4 narration) ===
# Same pattern as VLM_MODELS: comma-separated, primary first, fallbacks after.
# Used when primary returns empty / 429 / unparseable JSON.
# Last entry is a cheap paid model so worst-case never rate-limits.
LLM_MODELS=minimax/minimax-m2.5:free,deepseek/deepseek-chat-v3.1:free,meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.5-flash-lite

# === Vision LLM fallback chain for Stage 2 page preprocessing ===
# Comma-separated, priority order. First entry = primary model; the rest are
# fallbacks tried on 429 / rate-limit / unparseable JSON.
#
# OpenRouter free quota is PER-MODEL (50 RPD unfunded, 1000 RPD with $10+ credit).
# Picking 4 models from 4 different providers = 4 independent quota pools.
# Last entry is a cheap paid model so worst-case can never rate-limit
# (Gemini 2.5 Flash Lite ≈ $0.0002 / comic page).
VLM_MODELS=google/gemma-4-31b-it:free,qwen/qwen2.5-vl-72b-instruct:free,nvidia/nemotron-nano-12b-v2-vl:free,google/gemini-2.5-flash-lite

# === Web search / wiki extract ===
TAVILY_API_KEY=your_tavily_api_key_here

# === Fandom wikis (Stage 1 plot synopsis fetch via MediaWiki Action API) ===
# Comma-separated, in priority order. Add more here as you onboard new publishers.
# When the comic's publisher is known, the matching wiki is tried first.
FANDOM_DOMAINS=marvel.fandom.com,dc.fandom.com,imagecomics.fandom.com

# === TTS (Cartesia) — Stage 4 ===
CARTESIA_API_KEY=your_cartesia_api_key_here
# sonic-3 pinned snapshot has full speed + volume + emotion controls.
# sonic-3.5 has speed/volume disabled temporarily — switch when Cartesia re-enables.
CARTESIA_MODEL=sonic-3-2026-01-12
CARTESIA_API_VERSION=2026-03-01
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# === Pipeline Mode & Agent ===
# narrate_1_comic (default) | story_arc | character_feat | versus | what_if | origin_story | top_moments
# PIPELINE_MODE=narrate_1_comic
# Max retries per phase when user rejects a result (default: 3)
# MAX_PHASE_RETRIES=3

# === Comic Scraper ===
ENABLE_COMIC_SCRAPER=true
# headless=false opens a visible Chrome window (more reliable vs Cloudflare)
COMIC_SCRAPER_HEADLESS=false

# === Stage 5: Video assembly ===
# Optional background music path (relative to project root). Pipeline no-ops if file missing.
BG_MUSIC_PATH=assets/bgm/default.mp3
# Custom ffmpeg binary. Stage 5 needs libass + libfreetype for the subtitles filter,
# which is missing from the default brew bottle. Default points to a bundled Apple Silicon
# static build at ./bin/ffmpeg (osxexperts.net ffmpeg 8.1). Set to "ffmpeg" to use system.
FFMPEG_BIN=bin/ffmpeg
