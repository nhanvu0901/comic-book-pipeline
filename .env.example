# === LLM (OpenRouter) ===
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Default is anthropic/claude-haiku-4-5 (good tool use, cheap). Alternatives:
#   OPENROUTER_MODEL=google/gemini-2.5-flash        # cheapest, fast, solid tool use
#   OPENROUTER_MODEL=anthropic/claude-sonnet-4-5    # strongest, pricier
#   OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1    # free tier available
# OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# === Vision LLM for Stage 2 page preprocessing (OpenRouter) ===
# Free-tier vision model used to extract text, speakers, and panel descriptions
# from comic pages. Keep this to a free model unless you want to pay per page.
VLM_MODEL=google/gemma-4-26b-a4b-it:free

# === Web search / wiki extract ===
TAVILY_API_KEY=your_tavily_api_key_here

# === TTS (Cartesia) — Stage 4 ===
CARTESIA_API_KEY=your_cartesia_api_key_here
# sonic-2 is the current production model (2026). Barbershop Man voice ID below.
CARTESIA_MODEL=sonic-2
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# === Project Storage (OPTIONAL) ===
# If not set, projects are stored locally in ./projects/ folder
# GDRIVE_BASE=~/Library/CloudStorage/GoogleDrive-you@gmail.com/My Drive/comic-pipeline

# === Comic Scraper ===
ENABLE_COMIC_SCRAPER=true
# headless=false opens a visible Chrome window (more reliable vs Cloudflare)
COMIC_SCRAPER_HEADLESS=false
